<form>
	<title>Page Media</title>
	<description>Shared media fields (images, etc.) that are locale-independent. Reference this component from any page — all locales point to the same file so editors only update images in one place.</description>
	<objectType>component</objectType>
	<content-type>/component/page-media</content-type>
	<imageThumbnail>undefined</imageThumbnail>
	<quickCreate>false</quickCreate>
	<quickCreatePath>/site/components/shared</quickCreatePath>
	<properties>
		<property>
			<name>display-template</name>
			<label>Display Template</label>
			<value></value>
			<type>template</type>
		</property>
		<property>
			<name>no-template-required</name>
			<label>No Template Required</label>
			<value>true</value>
			<type>boolean</type>
		</property>
		<property>
			<name>merge-strategy</name>
			<label>Merge Strategy</label>
			<value>inherit-levels</value>
			<type>string</type>
		</property>
	</properties>
	<sections>
		<section>
			<title>Media Settings</title>
			<description></description>
			<defaultOpen>true</defaultOpen>
			<fields>
				<field>
					<type>file-name</type>
					<id>file-name</id>
					<iceId></iceId>
					<title>File Name</title>
					<description></description>
					<defaultValue></defaultValue>
					<help></help>
					<properties>
						<property>
							<name>size</name>
							<value>50</value>
							<type>int</type>
						</property>
						<property>
							<name>maxlength</name>
							<value>50</value>
							<type>int</type>
						</property>
						<property>
							<name>readonly</name>
							<value></value>
							<type>boolean</type>
						</property>
					</properties>
					<constraints></constraints>
				</field>
				<field>
					<type>input</type>
					<id>internal-name</id>
					<iceId></iceId>
					<title>Internal Name</title>
					<description></description>
					<defaultValue></defaultValue>
					<help></help>
					<properties>
						<property>
							<name>size</name>
							<value>50</value>
							<type>int</type>
						</property>
						<property>
							<name>maxlength</name>
							<value>60</value>
							<type>int</type>
						</property>
						<property>
							<name>readonly</name>
							<value></value>
							<type>boolean</type>
						</property>
						<property>
							<name>tokenize</name>
							<value>false</value>
							<type>boolean</type>
						</property>
					</properties>
					<constraints>
						<constraint>
							<name>required</name>
							<value><![CDATA[true]]></value>
							<type>boolean</type>
						</constraint>
					</constraints>
				</field>
				<field>
					<type>image-picker</type>
					<id>hero_image_s</id>
					<iceId>hero_image</iceId>
					<title>Hero Image</title>
					<description>Main banner image — shared across all languages. Upload once, applies everywhere.</description>
					<defaultValue></defaultValue>
					<help></help>
					<properties>
						<property>
							<name>imageManager</name>
							<value>sharedImages</value>
							<type>datasource:image</type>
						</property>
						<property>
							<name>readonly</name>
							<value></value>
							<type>boolean</type>
						</property>
					</properties>
					<constraints>
						<constraint>
							<name>required</name>
							<value><![CDATA[false]]></value>
							<type>boolean</type>
						</constraint>
					</constraints>
				</field>
			</fields>
		</section>
	</sections>
	<datasources>
		<datasource>
			<type>img-desktop-upload</type>
			<id>sharedImages</id>
			<title>Shared Images</title>
			<interface>image</interface>
			<properties>
				<property>
					<name>repoPath</name>
					<value>/static-assets/images/shared/</value>
					<type>undefined</type>
				</property>
			</properties>
		</datasource>
	</datasources>
</form>

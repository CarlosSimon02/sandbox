<translation-config>

	<!-- Supported locales for this site -->
	<localeCodes>
		<localeCode>en</localeCode>
		<localeCode>es</localeCode>
	</localeCodes>

	<!-- Default locale used when creating new content -->
	<defaultLocaleCode>en</defaultLocaleCode>

	<!-- Fall back to the default locale when no resolver matches -->
	<fallbackToDefaultLocale>true</fallbackToDefaultLocale>

	<!--
	    Locale resolvers are tried in order until one returns a locale.
	    - urlPattern: detects locale from the URL path (/en/... or /es/...)
	    - header:     uses the Accept-Language HTTP header (browser preference)
	-->
	<localeResolvers>
		<localeResolver>
			<type>urlPattern</type>
			<mappings>
				<mapping>
					<pattern>/en(/.*)?</pattern>
					<localeCode>en</localeCode>
				</mapping>
				<mapping>
					<pattern>/es(/.*)?</pattern>
					<localeCode>es</localeCode>
				</mapping>
			</mappings>
		</localeResolver>
		<localeResolver>
			<type>header</type>
		</localeResolver>
	</localeResolvers>

</translation-config>

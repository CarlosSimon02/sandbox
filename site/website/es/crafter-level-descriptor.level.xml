<?xml version="1.0" encoding="UTF-8"?>
<component>
	<content-type>/component/level-descriptor</content-type>
	<display-template/>
	<merge-strategy>inherit-levels</merge-strategy>
	<file-name>crafter-level-descriptor.level.xml</file-name>
	<folder-name/>
	<!--
	    Fields placed here are inherited by all pages under /site/website/es/.
	    Use this for values shared across all Spanish pages.

	    Example:
	    <hero_image_s>/static-assets/images/hero.jpg</hero_image_s>

	    The same static asset path can be used here as in the English level
	    descriptor — no separate copy of the image is needed.
	-->
</component>

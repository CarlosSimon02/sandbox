<?xml version="1.0" encoding="UTF-8"?>
<component>
	<content-type>/component/level-descriptor</content-type>
	<display-template/>
	<merge-strategy>inherit-levels</merge-strategy>
	<file-name>crafter-level-descriptor.level.xml</file-name>
	<folder-name/>
	<!--
	    Fields placed here are inherited by all pages under /site/website/en/.
	    Use this for values shared across all English pages, such as a default
	    hero image path that editors don't need to set on every page.

	    Example:
	    <hero_image_s>/static-assets/images/hero.jpg</hero_image_s>

	    Because static assets live in /static-assets/ (outside locale folders),
	    the same image path works in every locale's level descriptor or page XML
	    with no duplication.
	-->
</component>
